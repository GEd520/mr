{
  "name": "native-proxy",
  "version": "0.1.0",
  "description": "Rust native bridge for CORS proxy - HTML parsing, crypto, HTTP, URL",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "native-proxy",
    "triples": {
      "defaults": true,
      "additional": [
        "armv7-linux-androideabi",
        "aarch64-linux-android",
        "x86_64-linux-android",
        "i686-linux-android"
      ]
    }
  },
  "scripts": {
    "build": "napi build --release",
    "build:debug": "napi build",
    "prebuild": "napi prebuild",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2"
  }
}
